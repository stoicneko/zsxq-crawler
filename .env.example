# 知识星球 Cookie (必填)
# 从浏览器 DevTools -> Network 中获取 zsxq_access_token
# 格式: zsxq_access_token=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
ZSXQ_COOKIE="zsxq_access_token=YOUR_TOKEN_HERE"

# 星球 Group ID (从 URL 提取)
ZSXQ_GROUP_ID="48412145525258"

# 请求间隔 (秒), 避免触发限流
ZSXQ_REQUEST_DELAY="3"

# 每批次请求数量, 超过后长暂停
ZSXQ_BATCH_SIZE="15"

# 批次间暂停时间 (秒)
ZSXQ_BATCH_PAUSE="180"

# 是否下载图片
ZSXQ_DOWNLOAD_IMAGES="true"

# 是否下载文件附件
ZSXQ_DOWNLOAD_FILES="true"

# 是否爬取评论
ZSXQ_CRAWL_COMMENTS="true"

# 输出目录
ZSXQ_OUTPUT_DIR="output"
